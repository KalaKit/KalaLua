//Build script for use with kalamake. Read more at https://github.com/kalakit/kalamake

#version 1.0

#references
name_bin: KalaLua1
dir_release: build/release-
dir_debug: build/debug-
name_lua: lua
dir_lua_rel: _external_shared/lua/release
dir_lua_deb: _external_shared/lua/debug

#global
compilerlauncher: ccache
standard: c++20
binarytype: shared
sources: "src"
headers: "include", "_external_shared"
warninglevel: normal
customflags: export-compile-commands

#profile debug-windows
binaryname: ${name_bin}d
compiler: clang-cl
buildtype: debug
buildpath: "${dir_debug}windows"
links: "${dir_lua_deb}/${name_lua}.lib"

#profile release-windows
binaryname: ${name_bin}
compiler: clang-cl
buildtype: release
buildpath: "${dir_release}windows"
links: "${dir_lua_rel}/${name_lua}.lib"

#profile debug-linux
binaryname: lib${name_bin}d
compiler: clang++
buildtype: debug
buildpath: "${dir_debug}linux"
links: "${dir_lua_deb}/lib${name_lua}.a"
linkflags: Wl,-z,defs

#profile release-linux
binaryname: lib${name_bin}
compiler: clang++
buildtype: release
buildpath: "${dir_release}linux"
links: "${dir_lua_rel}/lib${name_lua}.a"
linkflags: Wl,-z,defs
postbuildaction: strip --strip-unneeded ${dir_release}linux/lib${name_bin}.so
